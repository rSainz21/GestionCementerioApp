{
  "name": "cementerio-pwa-apk",
  "private": true,
  "version": "0.1.0",
  "description": "Wrapper Android (Capacitor) para instalar la PWA /movil como APK.",
  "scripts": {
    "cap:init": "cap init cementerio-pwa-apk com.somahoz.cementerio --web-dir=www",
    "cap:add:android": "cap add android",
    "cap:open:android": "cap open android",
    "cap:sync": "cap sync",
    "cap:run:android": "cap run android",
    "cap:build:apk:debug": "cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "typescript": "^5.9.2"
  }
}

