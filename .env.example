APP_NAME="Cementerio Somahoz"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Madrid
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# LOCAL: SQLite (desarrollo)
DB_CONNECTION=sqlite
# DB_DATABASE ruta absoluta o relativa a /database/database.sqlite
# Se crea automáticamente con: touch database/database.sqlite

# PRODUCCIÓN: MySQL (descomentar cuando se integre en Conect@ 2.0)
#DB_CONNECTION=mysql
#DB_HOST=10.10.20.31
#DB_PORT=3317
#DB_DATABASE=conecta2
#DB_USERNAME=conecta_user
#DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@somahoz.es"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_EXPIRATION=

# --- Opcional: usar datos del servidor del compañero desde tu PC ---
# Si lo activas, tu Laravel local reenvía TODAS las llamadas /api/* al remoto (sin CORS).
#USE_REMOTE_API_PROXY=true
#REMOTE_API_BASE=http://192.168.100.69:8000
