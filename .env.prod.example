APP_NAME="Cementerio Somahoz"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Madrid
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=cementerio
DB_USERNAME=cementerio
DB_PASSWORD=cambia_esto

# Usado por el servicio mysql en docker-compose.prod.yml (no por Laravel directamente)
DB_ROOT_PASSWORD=cambia_esto_tambien

# En Docker prod suele ser mejor evitar escrituras de cache en disco si hay restricciones.
# Si prefieres persistencia real de caché, usa redis o database según tu escenario.
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log

SANCTUM_EXPIRATION=
