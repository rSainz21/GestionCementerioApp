APP_NAME="Cementerio Somahoz"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Ajustar con la IP real del servidor
APP_URL=http://10.10.20.31:8182
APP_TIMEZONE=Europe/Madrid
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────
# BASE DE DATOS
# IMPORTANTE: dentro del contenedor usar SIEMPRE el nombre del
# servicio Docker ("cementerio_db") y el puerto INTERNO (3306).
# Nunca usar localhost, 127.0.0.1 ni el puerto externo 3318.
# ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=cementerio_db
DB_PORT=3306
DB_DATABASE=cementerio
DB_USERNAME=cementerio_user
DB_PASSWORD=cementerio_pass

BROADCAST_CONNECTION=log
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@somahoz.es"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_EXPIRATION=
